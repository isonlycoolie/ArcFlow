#!/usr/bin/env bash
# Strips Cursor co-author trailers so commits reflect human authorship only.
# Install: bash scripts/install-git-hooks.sh

set -euo pipefail

msg_file="${1:?commit message file required}"
tmp="${msg_file}.arcflow-hook.$$"
grep -v '^Co-authored-by: Cursor <cursoragent@cursor.com>$' "$msg_file" >"$tmp" || true
mv "$tmp" "$msg_file"
