{
  "name": "arcflow",
  "version": "0.1.0",
  "description": "ArcFlow TypeScript SDK — workflow orchestration via Rust runtime",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.native.js",
    "index.ts",
    "arcflow",
    "arcflow-node.*.node"
  ],
  "scripts": {
    "build:native": "cargo build --release -p arcflow-node",
    "build:ts": "tsc --project tsconfig.json",
    "build": "npm run build:native && npm run build:ts",
    "test": "jest",
    "prepublishOnly": "node scripts/verify-no-credentials.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT OR Apache-2.0",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  }
}
