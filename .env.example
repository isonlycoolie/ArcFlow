# ArcFlow local development — copy to `.env` and adjust (never commit `.env`).
# See OPEN_SOURCE.md and server/arcflow-server/README.md.

# --- Server (required for arcflow-server) ---
ARCFLOW_SERVER_API_KEY=dev-change-me
ARCFLOW_ADMIN_API_KEY=dev-admin-change-me
ARCFLOW_POSTGRESQL_URL=postgres://arcflow:arcflow@localhost:5432/arcflow
ARCFLOW_PORT=8080

# --- Server (optional) ---
# ARCFLOW_WEBHOOK_SECRET=
# ARCFLOW_PG_MAX_CONNECTIONS=10
# ARCFLOW_DEFAULT_UPSTREAM_RUNTIME_KEY=
# ARCFLOW_STATIC_RUNTIME_KEYS={"site-id":"runtime-key"}
# ARCFLOW_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# ARCFLOW_DEBUG=false
# ARCFLOW_OTEL_ENABLED=false

# --- LLM providers (embedded / SDK runs; not stored by server traces) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
