# ArcFlow — git tracks code and machine contracts only

# Documentation pipeline
/docs/

# Private webapp (nested repo → github.com/isonlycoolie/ArcFlow-WebApp)
/webapp/

# Sprint working plans (local only — never commit)
arcflow_sprint01.md
arcflow_sprint*.md
ArcFlow_Sprint*_Implementation_Plan.md

# Self-hosted improvement plans (local only — never commit)
ArcFlow_Improvement_Plans/

# Cursor IDE — local agent skills, rules, settings (never commit)
.cursor/

# GitHub — workflows + branch policy + PR template tracked
.github/*
!.github/workflows/
!.github/workflows/**
!.github/BRANCH_POLICY.md
!.github/pull_request_template.md

# Sprint acceptance evidence — not in git (share via Slack / internal tooling only)
contracts/sprint1-acceptance-evidence.md
contracts/sprint*-acceptance-evidence.md

# Local git hook sources (installed via scripts/install-git-hooks.sh into .git/hooks)
scripts/hooks/

# Operator dashboard spec + UI live in ArcFlow-Dashboard (private repo), not this monorepo
/dashboard/

# Local PyPI upload token (scripts/publish-pypi.ps1)
scripts/.pypi-token

# Local smoke harness (not part of the product)
/test-app/

# Rust build
/target/

# Environment
.env
.env.*
!.env.example

# Local GitHub Actions runner (nektos/act) — binaries, secrets, events (never commit)
.local/

# Editor / OS
*.swp
*.swo
.DS_Store

# Future SDK / tooling artifacts (stubs may add these later)
__pycache__/
*.pyc
node_modules/
dist/
.gradle/
build/
*.class
